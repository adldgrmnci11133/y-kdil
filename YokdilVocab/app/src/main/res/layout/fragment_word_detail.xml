<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/colorPrimary">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvWord"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="hypothesis"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                    <ImageButton
                        android:id="@+id/btnFavorite"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/btn_star_big_off"
                        android:tint="@color/colorGold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPartOfSpeech"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="noun"
                    android:textSize="14sp"
                    android:textColor="#80FFFFFF" />

                <TextView
                    android:id="@+id/tvExamYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="YÖKDİL 2022"
                    android:textSize="12sp"
                    android:textColor="#80FFFFFF" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Meaning -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TÜRKÇE ANLAMI"
                    android:textSize="11sp"
                    android:textColor="@color/colorTextSecondary"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvMeaning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="hipotez, varsayım"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextPrimary" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Synonyms -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EŞ ANLAMLISI"
                    android:textSize="11sp"
                    android:textColor="@color/colorTextSecondary"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvSynonyms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="assumption, theory, supposition"
                    android:textSize="16sp"
                    android:textColor="@color/colorCorrect" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Antonyms -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ZIT ANLAMLISI"
                    android:textSize="11sp"
                    android:textColor="@color/colorTextSecondary"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvAntonyms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="fact, proof, certainty"
                    android:textSize="16sp"
                    android:textColor="@color/colorWrong" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Example -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ÖRNEK CÜMLE"
                    android:textSize="11sp"
                    android:textColor="@color/colorTextSecondary"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvExample"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="The hypothesis was supported by experimental evidence."
                    android:textSize="16sp"
                    android:textStyle="italic"
                    android:textColor="@color/colorTextPrimary" />

                <TextView
                    android:id="@+id/tvExampleTranslation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Hipotez, deneysel kanıtlarla desteklendi."
                    android:textSize="14sp"
                    android:textColor="@color/colorTextSecondary" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
